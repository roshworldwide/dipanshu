{
  "name": "venture-collective",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.css": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "3.9.1",
    "@react-three/drei": "9.114.0",
    "@react-three/fiber": "8.17.10",
    "@react-three/postprocessing": "2.16.3",
    "@vercel/analytics": "1.4.1",
    "framer-motion": "11.11.17",
    "gsap": "3.12.5",
    "lenis": "1.1.18",
    "next": "14.2.35",
    "postprocessing": "6.36.4",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "7.53.2",
    "three": "0.169.0",
    "zod": "3.23.8",
    "zustand": "4.5.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.1",
    "@playwright/test": "1.49.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/three": "0.169.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "husky": "9.1.7",
    "leva": "0.9.35",
    "lint-staged": "15.2.11",
    "postcss": "^8",
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.9",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
